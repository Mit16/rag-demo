# .env.example — Example environment variables for rag-demo
# Copy this file to .env and fill in your values (do not commit .env to Git)

# Ollama model for embeddings
EMBED_MODEL=nomic-embed-text

# Ollama model for LLM inference
LLM_MODEL=phi3:mini

# Path to your FAISS vectorstore
VECTORSTORE_PATH=vectorstore

# Maximum number of retries for retrieval
MAX_RETRIES=2